{
  "name": "math-lang-extension",
  "displayName": "Math Lang Extension",
  "description": "Syntax Highlighting for math-lang",
  "repository": "https://github.com/revival0728/math-lang-vsc-extension",
  "version": "0.1.0",
  "icon": "icons/extension.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "math-lang-hsingfu",
      "aliases": ["math-lang", "math-lang-hsingfu"],
      "extensions": [".mls"],
      "configuration": "./language-configuration.json",
      "icon": {
        "light": "icons/file-light.svg",
        "dark": "icons/file-dark.svg"
      }
    }],
    "grammars": [{
      "language": "math-lang-hsingfu",
      "scopeName": "source.mls",
      "path": "./syntaxes/math-lang-hsingfu.tmLanguage.json"
    }]
  }
}
